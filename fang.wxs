<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Fang"
    Manufacturer="Eric Gregory"
    Version="!(bind.FileVersion.FangExe)"
    UpgradeCode="7D9C9D7E-A404-42DA-9D60-6F5C5E31D8B9"
    InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Fang is already installed." />

    <Media Id="1" Cabinet="product.cab" EmbedCab="yes" />

    <Icon Id="ProductIcon" SourceFile="icons/win32.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="ARPHELPLINK" Value="http://www.getfang.com" />
    <Property Id="ARPURLINFOABOUT" Value="http://www.getfang.com" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="FangPath" Name="Fang">
        <Component Id="FangExeComponent" Guid="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D">
          <File Id="FangExe" Source="build/Release/Fang.exe" KeyPath="yes" />
        </Component>
        <Component Id="FeedProtocolHandler" Guid="B2C3D4E5-F6A7-5B6C-9D0E-1F2A3B4C5D6E">
          <!-- feed:// protocol -->
          <RegistryKey Root="HKCU" Key="Software\Classes\feed">
            <RegistryValue Type="string" Value="URL:RSS Feed Protocol" />
            <RegistryValue Name="URL Protocol" Type="string" Value="" />
            <RegistryKey Key="DefaultIcon">
              <RegistryValue Type="string" Value="[FangPath]Fang.exe,0" />
            </RegistryKey>
            <RegistryKey Key="shell\open\command">
              <RegistryValue Type="string" Value="&quot;[FangPath]Fang.exe&quot; &quot;%1&quot;" />
            </RegistryKey>
          </RegistryKey>
          <!-- feeds:// protocol (SSL variant) -->
          <RegistryKey Root="HKCU" Key="Software\Classes\feeds">
            <RegistryValue Type="string" Value="URL:RSS Feed Protocol (Secure)" />
            <RegistryValue Name="URL Protocol" Type="string" Value="" />
            <RegistryKey Key="DefaultIcon">
              <RegistryValue Type="string" Value="[FangPath]Fang.exe,0" />
            </RegistryKey>
            <RegistryKey Key="shell\open\command">
              <RegistryValue Type="string" Value="&quot;[FangPath]Fang.exe&quot; &quot;%1&quot;" />
            </RegistryKey>
          </RegistryKey>
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="ApplicationShortcuts" Guid="23DEE789-2730-40D9-92B2-81357F8B10D1">
        <Shortcut
          Id="ApplicationShortcut1"
          Name="Fang"
          Description="Fang RSS Reader"
          Target="[FangPath]Fang.exe"
          WorkingDirectory="FangPath" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Fang"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <RemoveFolder Id="ProgramMenuSubfolder" On="uninstall" />
      </Component>
    </StandardDirectory>

    <Feature Id="DefaultFeature" Level="1">
      <ComponentGroupRef Id="FangFilesGroup" />
      <ComponentRef Id="FangExeComponent" />
      <ComponentRef Id="ApplicationShortcuts" />
      <ComponentRef Id="FeedProtocolHandler" />
    </Feature>
  </Package>
</Wix>
