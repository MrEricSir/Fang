%2D8932%2D8671549dff1c%2F3d0a673c%2D1315%2D4265%2D8932%2D8671549dff1c.jpg&w=768&h=432&scale=crop&cquality=80&location=origin&format=jpg, https://a.espncdn.com/combiner/i?img=%2Fmedia%2Fmotion%2Fwsc%2F2026%2F0318%2F3d0a673c%2D1315%2D4265%2D8932%2D8671549dff1c%2F3d0a673c%2D1315%2D4265%2D8932%2D8671549dff1c.jpg&w=1296&h=729&scale=crop&cquality=40&location=origin&format=jpg 2x" media="(min-width: 376px)"><img  data-default-src="https://a.espncdn.com/media/motion/wsc/2026/0318/3d0a673c-1315-4265-8932-8671549dff1c/3d0a673c-1315-4265-8932-8671549dff1c.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a><span class="video-play-button  restricted" data-playTxt="PLAY" data-id="48236570"></span><span class="video-length">0:21</span></div></figure></li><li class="text-container"><h2><a name="&lpos=hp-rightrail:video:3" href="/video/clip?id=48236570">Tramon Mark hits clutch winner with 1.1 left for Texas</a></h2><p>Tramon Mark hits a smooth jumper with 1.1 seconds left to lift Texas past NC State.</p></li></ul> <!-- close content --></article><article class="sub-module editorial"><header class=""><h2 class="">ESPN is now the home of MLB.TV</h2></header><ul class="content"><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:4" href="https://plus.espn.com/mlbtv" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0210%2Fr1613162_1296x729_16%2D9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0210%2Fr1613162_1296x729_16%2D9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0210%2Fr1613162_1296x729_16%2D9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0210%2Fr1613162_1296x729_16%2D9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0210/r1613162_1296x729_16-9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">ESPN</span></figure></li><li class="text-container"><h2><a name="&lpos=hp-rightrail:other:4" href="https://plus.espn.com/mlbtv">All MLB out-of-market Games. Live or On Demand. All in One Place.</a></h2><p></p></li></ul> <!-- close content --></article><article class="sub-module editorial"><header class=""><h2 class="">Sounding Off</h2></header><ul class="content"><li><figure class="feed-item-figure video " data-source="espn" data-contributing-partner="wsc" data-video="watch,640,360,48231031" data-cerebro-id="69b9686edbad3347c508faf0"><div class="img-wrap"><a name="&lpos=hp-rightrail:image:5" href="https://www.espn.com/video/clip?id=48231031" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fmedia%2Fmotion%2F2026%2F0317%2F17972c34aa11433d8decf2c8960433d2646%2F17972c34aa11433d8decf2c8960433d2646.jpg&w=375&h=210&scale=crop&cquality=80&location=origin, https://a3.espncdn.com/combiner/i?img=%2Fmedia%2Fmotion%2F2026%2F0317%2F17972c34aa11433d8decf2c8960433d2646%2F17972c34aa11433d8decf2c8960433d2646.jpg&w=768&h=432&scale=crop&cquality=40&location=origin&format=jpg 2x" media="(max-width: 375px)"><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fmedia%2Fmotion%2F2026%2F0317%2F17972c34aa11433d8decf2c8960433d2646%2F17972c34aa11433d8decf2c8960433d2646.jpg&w=768&h=432&scale=crop&cquality=80&location=origin&format=jpg, https://a3.espncdn.com/combiner/i?img=%2Fmedia%2Fmotion%2F2026%2F0317%2F17972c34aa11433d8decf2c8960433d2646%2F17972c34aa11433d8decf2c8960433d2646.jpg&w=1296&h=729&scale=crop&cquality=40&location=origin&format=jpg 2x" media="(min-width: 376px)"><img  data-default-src="https://a.espncdn.com/media/motion/2026/0317/17972c34aa11433d8decf2c8960433d2646/17972c34aa11433d8decf2c8960433d2646.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a><span class="video-play-button " data-playTxt="PLAY" data-id="48231031"></span><span class="video-length">2:44</span></div></figure></li><li class="text-container"><h2><a name="&lpos=hp-rightrail:video:5" href="/video/clip?id=48231031">Stephen A. stunned by Orlovsky's take on gap between Mendoza and Simpson</a></h2><p>Stephen A. Smith and Dan Orlovsky compare Ty Simpson and Fernando Mendoza as prospects ahead of the NFL draft.</p></li></ul> <!-- close content --></article><article class="sub-module editorial"><header class=""><h2 class="">Trending Now</h2></header><ul class="content"><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:6" href="/nfl/draft2026/story/_/id/48215816/2026-nfl-mock-draft-kiper-32-picks-predictions-post-free-agency-round-1" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a4.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fnfl_kiper_mock_3_16x9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a4.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fnfl_kiper_mock_3_16x9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a4.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fnfl_kiper_mock_3_16x9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a4.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fnfl_kiper_mock_3_16x9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0316/nfl_kiper_mock_3_16x9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">Nick Fancher for ESPN, Getty Images</span></figure></li><li class="text-container" data-id="48215816"><h2><a name="&lpos=hp-rightrail:story:48215816:6" href="/nfl/draft2026/story/_/id/48215816/2026-nfl-mock-draft-kiper-32-picks-predictions-post-free-agency-round-1">2026 NFL mock draft: Mel Kiper's pick predictions for Round 1</a></h2><p>Team needs have shifted in free agency, so how will top prospects come off the board in Round 1? Mel Kiper Jr. projects the NFL draft's first 32 picks.</p></li><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:7" href="/mens-college-basketball/story/_/id/48223542/ncaa-tournament-upsets-first-round-giant-killers-march-madness-2026" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a2.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629618_800x450_16%2D9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a2.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629618_800x450_16%2D9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a2.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629618_800x450_16%2D9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a2.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629618_800x450_16%2D9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0317/r1629618_800x450_16-9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">Nicholas Faulkner/Icon Sportswire</span></figure></li><li class="text-container" data-id="48223542"><h2><a name="&lpos=hp-rightrail:story:48223542:7" href="/mens-college-basketball/story/_/id/48223542/ncaa-tournament-upsets-first-round-giant-killers-march-madness-2026">Most probable first-round upsets in the men's 2026 NCAA tournament</a></h2><p>Which double-digit seeds have the highest potential to advance to the second round? Here's what ESPN's BPI says.</p></li><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:8" href="/mlb/story/_/id/48232543/mlb-world-baseball-classic-2029-team-usa-roster-predictions" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629802_608x342_16%2D9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629802_608x342_16%2D9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629802_608x342_16%2D9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0317%2Fr1629802_608x342_16%2D9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0317/r1629802_608x342_16-9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">Houston Astros/Getty Images</span></figure></li><li class="text-container" data-id="48232543"><h2><a name="&lpos=hp-rightrail:story:48232543:8" href="/mlb/story/_/id/48232543/mlb-world-baseball-classic-2029-team-usa-roster-predictions">Way-too-early 2029 World Baseball Classic Team USA roster</a></h2><p>Team USA just lost to Venezuela -- but the future is still bright. Here's who could play for the U.S. in the next World Baseball Classic.</p></li><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:9" href="/womens-college-basketball/story/_/id/48224437/womens-march-madness-2026-bracket-ncaa-tournament-best-guards-blakes" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0313%2Fncaaw_underclassman%2Dguards_16x9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0313%2Fncaaw_underclassman%2Dguards_16x9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0313%2Fncaaw_underclassman%2Dguards_16x9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0313%2Fncaaw_underclassman%2Dguards_16x9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0313/ncaaw_underclassman-guards_16x9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">Illustration by ESPN</span></figure></li><li class="text-container" data-id="48224437"><h2><a name="&lpos=hp-rightrail:story:48224437:9" href="/womens-college-basketball/story/_/id/48224437/womens-march-madness-2026-bracket-ncaa-tournament-best-guards-blakes">Ranking the top underclass guards in women's March Madness</a></h2><p>One must-see guard scores from anywhere like the WNBA's Kelsey Plum. Another handles pressure like Chelsea Gray.</p></li><li><figure class="feed-item-figure "><div class="img-wrap"><a name="&lpos=hp-rightrail:image:10" href="/nba/story/_/id/48223005/nba-expansion-seattle-las-vegas-draft-format-more-big-questions-teams-2028" data-sport="null" data-mptype="image"><picture ><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fr1629263_608x342_16%2D9.jpg&w=78&h=78&scale=crop&cquality=80&location=center, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fr1629263_608x342_16%2D9.jpg&w=156&h=156&scale=crop&cquality=40&location=center 2x" media="(max-width: 413px)"><source data-srcset="https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fr1629263_608x342_16%2D9.jpg&w=272&h=153&scale=crop&cquality=80&location=origin, https://a3.espncdn.com/combiner/i?img=%2Fphoto%2F2026%2F0316%2Fr1629263_608x342_16%2D9.jpg&w=544&h=306&scale=crop&cquality=80&location=origin&format=jpg 2x" media="(min-width: 414px)"><img  data-default-src="https://a.espncdn.com/photo/2026/0316/r1629263_608x342_16-9.jpg"  class=" lazyload" data-image-container=".feed-item-figure" ></picture></a></div><span class="credit">Photo by Joe Nicholson/USA TODAY Sports</span></figure></li><li class="text-container" data-id="48223005"><h2><a name="&lpos=hp-rightrail:story:48223005:10" href="/nba/story/_/id/48223005/nba-expansion-seattle-las-vegas-draft-format-more-big-questions-teams-2028">NBA expansion: Seattle, Las Vegas, draft format, news, updates</a></h2><p>The NBA seems closer than ever to adding two franchises. Here's what we know, including how an expansion draft could work.</p></li></ul> <!-- close content --></article><article class="sub-module fantasySignupV2 fantasySignup-baseball league-mgr" data-behavior="fantasy_signup" data-league="flb"><div class="content"><div class="fantasySignup__logo"><img class="default" alt="Play ESPN Fantasy baseball" src="https://a.espncdn.com/i/fantasy/rightRail/flb-title25.png"><img class="activeLeague" alt="Ready to Join Another League?" src="https://a.espncdn.com/i/fantasy/rightRail/flb-ReadyToJoin25.png"></div><h2 class="fantasySignup__title">Sign up to play the #1 Fantasy Baseball Game</h2><div class="fantasySignup__cta"><a class="button med" href="https://fantasy.espn.com/baseball/welcome?addata=right_rail_create_flb2026">Create A League</a><a class="button med" href="https://fantasy.espn.com/baseball/welcome?addata=right_rail_join_flb2026">Join a Public League</a><a class="button med" href="https://fantasy.espn.com/baseball/tools/reactivate?seasonId=2025&addata=flb_2026_right_rail_reactivate">Reactivate A League</a></div><div class="fantasySignup__footer"><a href="https://fantasy.espn.com/baseball/mockdraftlobby?addata=right_rail_mock_flb2026">Practice With a Mock Draft</a></div></div></article><article class="sub-module fantasySignupV2 fantasySignup-womens-basketball league-mgr" data-behavior="fantasy_signup" data-league="wfba"><div class="content"><div class="fantasySignup__logo"><img class="default" alt="Play ESPN Fantasy womens-basketball" src="https://a.espncdn.com/i/fantasy/rightRail/wfba-title25.png"><img class="activeLeague" alt="Ready to Join Another League?" src="https://a.espncdn.com/i/fantasy/rightRail/wfba-ReadyToJoin25.png"></div><h2 class="fantasySignup__title">Sign up for FREE!</h2><div class="fantasySignup__cta"><a class="button med" href="https://fantasy.espn.com/womens-basketball/tools/reactivate?seasonId=2025&addata=wfba2026_right_rail_reactivate">Reactivate A League</a><a class="button med" href="https://fantasy.espn.com/womens-basketball/welcome?addata=right_rail_create_wfba2026">Create A League</a><a class="button med" href="https://fantasy.espn.com/womens-basketball/welcome?addata=right_rail_join_wfba2026">Join a Public League</a></div><div class="fantasySignup__footer"><a href="https://fantasy.espn.com/womens-basketball/mockdraftlobby?addata=right_rail_mock_wfba2026">Practice With a Mock Draft</a></div></div></article><div id="favfeed-footer"></div></section>
